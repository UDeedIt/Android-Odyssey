<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.AndroidOdyssey.Splash" parent="Theme.SplashScreen">
        <!-- Background color of the system splash screen -->
        <item name="windowSplashScreenBackground">@color/black</item>

        <!-- Icon shown in the center of the splash (vector/png/animated drawable) -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>

        <!-- Optional: background color behind the icon shape (if you use one) -->
        <item name="windowSplashScreenIconBackgroundColor">@color/purple_700</item>

        <!-- Theme to apply to the activity after the system splash disappears -->
        <item name="postSplashScreenTheme">@style/Theme.AndroidOdyssey</item>
    </style>
    
</resources>